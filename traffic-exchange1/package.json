{
  "name": "traffic-exchange",
  "version": "0.1.0",
  "private": true,
  "description": "Credit-based traffic exchange platform for URL shorteners",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "node server.js",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "db:push": "prisma db push",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "ioredis": "^5.4.1",
    "jose": "^5.9.6",
    "nanoid": "^5.0.9",
    "next": "14.2.18",
    "prisma": "^5.22.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "resend": "^4.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.17.6",
    "@types/react": "^18.3.12",
    "vitest": "^2.1.5"
  }
}
